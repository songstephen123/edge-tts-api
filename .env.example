# Service Configuration
SERVICE_PORT=8000
SERVICE_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated origins)
CORS_ORIGINS=*

# Default TTS Settings
DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
DEFAULT_RATE=+0%
DEFAULT_PITCH=+0Hz
DEFAULT_VOLUME=+0%

# Cache Settings
ENABLE_CACHE=true
CACHE_TTL=3600
